# =====================================================================
# CareerLoop backend — production environment template.
# Copy this file to `.env.prod` on the server and fill in real values.
# DO NOT commit the populated copy.
#
# Usage with docker-compose:
#   cp .env.prod.example .env.prod
#   vim .env.prod          # paste secrets
#   docker compose up -d   # docker-compose.yml reads .env.prod
# =====================================================================

# ----- HTTP -----
# Backend listens on this port inside the container; nginx proxies to it.
SERVER_PORT=8080

# ----- MySQL (Aliyun RDS or self-hosted) -----
MYSQL_HOST=rm-xxxxxxxx.mysql.rds.aliyuncs.com
MYSQL_PORT=3306
MYSQL_DB=career_db
MYSQL_USER=careerloop_app
MYSQL_PWD=                    # required, no default

# ----- Aliyun OSS (object storage for resumes / avatars) -----
OSS_ENDPOINT=oss-cn-chengdu.aliyuncs.com
OSS_BUCKET=careerloop-prod
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ----- Aliyun Tongyi Qianwen (AI text generation) -----
ALIYUN_AI_API_KEY=
ALIYUN_AI_MODEL=qwen-max

# ----- WeChat Mini Program -----
# These come from mp.weixin.qq.com → Development → Development Management
WECHAT_APPID=wx8bdae792853cc263
WECHAT_SECRET=

# ----- Email (verification codes via QQ SMTP, or override host/port) -----
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=                # NOT your QQ login password — the SMTP "授权码"
