# =====================================================================
# CareerLoop backend — production environment template.
# Copy this file to `.env.prod` on the server and fill in real values.
# DO NOT commit the populated copy.
#
# Usage with docker-compose:
#   cp .env.prod.example .env.prod
#   vim .env.prod          # paste secrets
#   docker compose up -d   # docker-compose.yml reads .env.prod
# =====================================================================

# ----- HTTP -----
# Backend listens on this port inside the container; nginx proxies to it.
SERVER_PORT=8080

# ----- MySQL (Docker-internal service name = mysql) -----
# MYSQL_ROOT_PASSWORD is used by the mysql container (not the app).
MYSQL_ROOT_PASSWORD=          # required — set a strong root password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=career_db
MYSQL_USER=careerloop_app
MYSQL_PWD=                    # required, no default

# ----- Aliyun OSS (object storage for resumes / avatars) -----
OSS_ENDPOINT=oss-cn-chengdu.aliyuncs.com
OSS_BUCKET=careerloop-prod
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ----- Aliyun Tongyi Qianwen (AI text generation) -----
ALIYUN_AI_API_KEY=
ALIYUN_AI_MODEL=qwen-max

# ----- WeChat Mini Program -----
# These come from mp.weixin.qq.com → Development → Development Management
WECHAT_APPID=wx8bdae792853cc263
WECHAT_SECRET=

# ----- Email (verification codes via QQ SMTP, or override host/port) -----
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=                # NOT your QQ login password — the SMTP "授权码"

# ----- JWT signing -----
# REQUIRED. Must be at least 32 bytes (256 bits). Generate with:
#   openssl rand -hex 32
# Rotating this invalidates all existing user sessions, so do it on a
# planned maintenance window.
JWT_SECRET=
JWT_EXPIRATION_MS=604800000

# ----- Redis (Docker-internal service name = redis) -----
# Leave REDIS_PASSWORD empty if you don't want a password (not recommended).
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=               # set a strong password; must match redis container command

# ----- WeChat Subscribe Message Templates (F10) -----
# Get template IDs from mp.weixin.qq.com > 功能 > 订阅消息
WECHAT_TPL_WEEKLY_REPORT=
WECHAT_TPL_INTERVIEW_REPORT=
WECHAT_TPL_ASSESSMENT=
WECHAT_TPL_RESUME_DIAGNOSIS=
WECHAT_TPL_AI_PROACTIVE=

# ----- ServerChan ERROR alert (F27) -----
# Get SendKey from https://sc.ftqq.com
SERVER_CHAN_SEND_KEY=
ALERT_SERVERCHAN_ENABLED=true
ALERT_EMAIL=3218778592@qq.com

# ----- Body Language sidecar (Phase 6 — interview body-language scoring) -----
# Internal docker-compose hostname; override only if running outside compose.
BODY_LANG_SIDECAR_URL=http://body-lang:8001

# ----- F21: AI service fallback mode -----
# Set to true to bypass all AI calls (use when DashScope is down or quota exhausted).
AI_FALLBACK_MODE=false

# ----- F29: Content safety -----
# Set to false to disable UGC/feedback content safety checks (e.g. in dev).
CONTENT_SAFETY_ENABLED=true
