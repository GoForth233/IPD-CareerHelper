server:
  port: 8080

spring:
  application:
    name: career-backend

  # ==============================
  # 1. MySQL
  # ==============================
  datasource:
    url: jdbc:mysql://${MYSQL_HOST:localhost}:${MYSQL_PORT:3306}/career_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
    username: ${MYSQL_USER:root}
    password: ${MYSQL_PWD:CHANGE_ME}
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    open-in-view: false
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

  # ==============================
  # 2. Mail SMTP
  # Examples:
  #   QQ:    MAIL_HOST=smtp.qq.com  MAIL_PORT=587
  #   163:   MAIL_HOST=smtp.163.com MAIL_PORT=465  MAIL_SSL=true
  #   Gmail: MAIL_HOST=smtp.gmail.com MAIL_PORT=587 MAIL_SSL=false
  # ==============================
  mail:
    host: ${MAIL_HOST:smtp.qq.com}
    port: ${MAIL_PORT:587}
    username: ${MAIL_USERNAME:your_email@example.com}
    password: ${MAIL_PASSWORD:your_smtp_authcode}
    default-encoding: UTF-8
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
            required: true
          ssl:
            enable: false

  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 10MB

knife4j:
  enable: true
  setting:
    language: en

# ==============================
# 3. Aliyun OSS
# ==============================
aliyun:
  oss:
    endpoint: oss-cn-chengdu.aliyuncs.com
    access-key-id: ${OSS_ACCESS_KEY_ID:CHANGE_ME}
    access-key-secret: ${OSS_ACCESS_KEY_SECRET:CHANGE_ME}
    bucket-name: ${OSS_BUCKET:career-resume-store}

  # ==============================
  # 4. Aliyun AI (Qwen / DeepSeek-compatible)
  # ==============================
  ai:
    api-key: ${ALIYUN_AI_API_KEY:CHANGE_ME}
    model: qwen-max

# ==============================
# 5. WeChat Mini Program
# ==============================
wechat:
  miniapp:
    appid: ${WECHAT_APPID:wxXXXXXXXXXXXXXXXX}
    secret: ${WECHAT_SECRET:CHANGE_ME}

# ==============================
# 6. JWT
# Generate a strong random hex secret of >= 256 bits, e.g.
#   openssl rand -hex 32
# ==============================
jwt:
  secret: ${JWT_SECRET:CHANGE_ME_TO_A_LONG_RANDOM_STRING}
  expiration-ms: 86400000        # 24h
  refresh-expiration-ms: 604800000 # 7d
